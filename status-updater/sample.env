# status-updater environment variables
# Copy this file to .env and fill in your values.
# Source before running: source .env

# ── AI summary (optional) ────────────────────────────────────────────────────
# When set, Claude Haiku rewrites work items into clean past-tense bullets.
# Without this, raw Jira/PR titles are used as-is.
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub repos to scan ─────────────────────────────────────────────────────
# Comma-separated list of owner/repo pairs.
GITHUB_REPOS=owner/repo1,owner/repo2

# ── Jira: method 1 — Claude Code MCP (preferred, zero-config) ────────────────
# If you have authenticated the atlassian-vdc-workspace MCP server in Claude Code,
# no credentials are needed here. The tool reads the OAuth token automatically from
# ~/.claude/.credentials.json and refreshes it when expired.
#
# One-time setup (only needed once per machine):
#   claude mcp add atlassian-vdc-workspace --transport http https://mcp.veeam.com/atlassian-vdc-workspace/mcp
#   Then start a Claude Code session — it will open a browser for OAuth login.
#
# Override the default Atlassian cloud ID if needed:
# JIRA_CLOUD_ID=yourorg.atlassian.net

# ── Jira: method 2 — acli ────────────────────────────────────────────────────
# Install acli from https://acli.atlassian.com and ensure it's on PATH.
# No env vars needed; the tool detects acli automatically via exec.LookPath.

# ── Jira: method 3 — REST API ────────────────────────────────────────────────
# All three must be set for REST to be used.
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token_here

# ── Jira: method 4 — stdio MCP subprocess (last resort) ──────────────────────
# JIRA_COMMAND=npx
# JIRA_ARGS=-y @atlassian/mcp-atlassian --jira-url https://yourorg.atlassian.net --jira-email you@example.com --jira-token your_token
